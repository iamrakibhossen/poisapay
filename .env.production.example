# ==========================================================================
# PoisaPay — PRODUCTION environment template
# Copy to .env on the target host and fill every <REQUIRED> value.
# NEVER commit a filled copy. Secrets belong in a vault / KMS, not here.
# ==========================================================================

APP_NAME=PoisaPay
APP_ENV=production
APP_KEY=                     # php artisan key:generate
# Secret rotation: after generating a new APP_KEY, move the OLD key here (comma-
# separated) so encrypted data still decrypts, then run `php artisan poisapay:reencrypt`.
APP_PREVIOUS_KEYS=
APP_DEBUG=false              # MUST be false in production
APP_URL=https://<your-domain>

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

# ---- Logging (send warnings+ to Slack for on-call visibility) ----
LOG_CHANNEL=stack
LOG_STACK=daily,slack
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# ---- Security ----
BCRYPT_ROUNDS=12
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true         # hardening: encrypt session payloads
SESSION_SECURE_COOKIE=true   # HTTPS-only cookies
SESSION_SAME_SITE=lax
SESSION_DOMAIN=<your-domain>

# ---- Database (PostgreSQL) ----
DB_CONNECTION=pgsql
DB_HOST=<REQUIRED>
DB_PORT=5432
DB_DATABASE=poisapay
DB_USERNAME=<REQUIRED>
DB_PASSWORD=<REQUIRED>

# ---- Redis (cache / queue / session / broadcast backplane) ----
REDIS_CLIENT=predis
REDIS_HOST=<REQUIRED>
REDIS_PASSWORD=<REQUIRED>
REDIS_PORT=6379

CACHE_STORE=redis
CACHE_PREFIX=poisapay
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

# ---- Mail ----
MAIL_MAILER=smtp
MAIL_HOST=<REQUIRED>
MAIL_PORT=587
MAIL_USERNAME=<REQUIRED>
MAIL_PASSWORD=<REQUIRED>
MAIL_FROM_ADDRESS="no-reply@<your-domain>"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Filesystem (KYC docs, statements → private S3) ----
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=<REQUIRED>
AWS_SECRET_ACCESS_KEY=<REQUIRED>
AWS_DEFAULT_REGION=<REQUIRED>
AWS_BUCKET=<REQUIRED>
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- Reverb (websockets) ----
REVERB_APP_ID=<REQUIRED>
REVERB_APP_KEY=<REQUIRED>
REVERB_APP_SECRET=<REQUIRED>
REVERB_HOST=<your-domain>

# ---- Ops alerting / observability ----
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
# Error tracking / APM (opt-in): composer require sentry/sentry-laravel, then set the DSN.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ==========================================================================
# Provider adapters (config/providers.php) — default to built-in stubs.
# Flip each to a real driver once the vendor account + driver class exist.
# ==========================================================================
RATES_DRIVER=stub                 # stub | coingecko | binance …
RATES_CACHE_TTL=60                # seconds; 0 disables the caching decorator
SCREENING_DRIVER=stub             # stub | complyadvantage | refinitiv …
KYC_DRIVER=manual                 # manual | sumsub | onfido | jumio …
PAYOUT_DRIVER=stub                # stub | wise | flutterwave …  (off-ramp PSP)
PAYOUT_WEBHOOK_SECRET=            # HMAC secret for the PSP payout webhook
SMS_DRIVER=log                    # log | twilio | vonage …
PUSH_DRIVER=log                   # log | fcm | apns …

# ==========================================================================
# PoisaPay platform config
# ==========================================================================
POISAPAY_BASE_CURRENCY=USD
POISAPAY_DEFAULT_SPREAD_BPS=50
POISAPAY_DEPOSIT_FEE_PERCENT=0
POISAPAY_WITHDRAWAL_FEE_PERCENT=0
POISAPAY_WITHDRAWAL_AUTO_APPROVE_LIMIT=50000
POISAPAY_CARD_AUTH_P99_MS=2000

# ---- Custody — DO NOT go live until backed by KMS/HSM (see roadmap Wave 1) ----
POISAPAY_CUSTODY_LIVE=false   # keep false until KMS-backed signer is deployed
POISAPAY_CUSTODY_SEED=        # TEMPORARY: env seed is testnet-only; replace with KMS

# ---- TRON ----
POISAPAY_TRON_RPC=https://api.trongrid.io
POISAPAY_TRONGRID_KEY=<REQUIRED for mainnet rate limits>
POISAPAY_TRON_USDT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
POISAPAY_TRON_CONFIRMATIONS=19

# ==========================================================================
# Card issuing — keep 'mock' until Marqeta field paths are verified (Card audit)
# ==========================================================================
CARD_PROVIDER=mock
CARD_JIT_TIMEOUT_MS=2000
CARD_HTTP_TIMEOUT=10
CARD_HTTP_RETRY_ATTEMPTS=2
CARD_HTTP_RETRY_SLEEP_MS=200
CARD_WEBHOOK_TOLERANCE=300
# Marqeta (fill when going live)
CARD_MARQETA_URL=
CARD_MARQETA_APP_TOKEN=
CARD_MARQETA_ADMIN_TOKEN=
CARD_MARQETA_CARD_PRODUCT_TOKEN=
CARD_MARQETA_NETWORK=
CARD_MARQETA_WEBHOOK_SECRET=
CARD_MARQETA_INBOUND_USER=
CARD_MARQETA_INBOUND_PASS=
